# Build artifacts
rust/target/

# Sandbox (browser profiles, temp files)
.sandbox-home/
.sandbox-tmp/

# Session data (runtime generated)
.claw/sessions/
.claw/images/

# Local settings (may contain secrets)
.claude/settings.local.json

# Plugin caches (embedded git repos, auto-downloaded)
.claude/plugins/cache/
.claude/plugins/marketplaces/

# OS files
Thumbs.db
Desktop.ini
.DS_Store

# Editor
*.swp
*.swo
*~

# Compiled binary
*.exe
!rust/crates/rusty-claude-cli/assets/**/*.exe
